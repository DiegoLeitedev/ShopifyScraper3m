# BuiltWith API Key (gratuita — https://api.builtwith.com/)
BUILTWITH_API_KEY=sua_chave_aqui

# SerpAPI Key (opcional — https://serpapi.com/)
SERPAPI_KEY=sua_chave_aqui

# Configurações gerais
MAX_WORKERS=10
REQUEST_TIMEOUT=15
DELAY_BETWEEN_REQUESTS=1.5

# CommonCrawl index (deixar padrão ou alterar para outro crawl)
COMMONCRAWL_INDEX=CC-MAIN-2024-10
